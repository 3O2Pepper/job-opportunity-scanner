# SQLite URL (default path is ./data/app.db)
DATABASE_URL=sqlite:///./data/app.db

# Gmail OAuth: download OAuth client JSON from Google Cloud Console as credentials.json
GMAIL_CREDENTIALS_PATH=data/credentials.json
GMAIL_TOKEN_PATH=data/tokens/gmail_token.json

# Gmail search query (edit senders/domains to match your inbox)
GMAIL_QUERY=(from:jobs-listings@linkedin.com OR from:linkedin.com OR subject:(job alert) OR subject:(internship) OR from:indeed.com OR from:glassdoor.com OR from:handshake.com OR subject:(career)) newer_than:90d

# Max messages per sync
GMAIL_SYNC_MAX_RESULTS=100

# Paid LLM — leave disabled unless you approve usage and billing
ENABLE_LLM=false
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
